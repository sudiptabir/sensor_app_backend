# Environment Variables for Alert API
# Copy these to your host (EC2/Railway) environment configuration

# Firebase Service Account Configuration
FIREBASE_PROJECT_ID=rutag-app
FIREBASE_PRIVATE_KEY_ID=your_private_key_id_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@rutag-app.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id_here
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40sensor-app-2a69b.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://rutag-app-default-rtdb.asia-southeast1.firebasedatabase.app

# Server Configuration
NODE_ENV=production
PORT=3000